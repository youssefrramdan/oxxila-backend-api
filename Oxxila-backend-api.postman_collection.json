{
  "info": {
    "_postman_id": "1e24d623-738e-4745-ad67-af09c0aca44c",
    "name": "Oxxila-backend-api",
    "description": "Oxxila e-commerce REST API.\n\n## Structure\n- **Health Check** — liveness probe.\n- **Authentication** — signup/login, session management, password reset.\n- **Current User** — everything the logged-in user can do on their own account.\n- **Admin User Management** — admin-only user CRUD + moderation actions.\n\n## Tokens\n- **Access token** (15m) — returned in the response body and stored in the `token` env var. Sent via `Authorization: Bearer {{token}}`.\n- **Refresh token** (7d) — set by the server as an `httpOnly`, `Secure`, `SameSite=Strict` cookie scoped to `/api/v1/auth`. Postman's Cookie Jar sends it automatically.\n\n## Typical flow\nSignup/Login → call protected endpoints → when the access token expires, call **Authentication / Signup & Login / Refresh Access Token** → new access token is saved to `{{token}}` → **Logout** revokes the session.\n\nSelect the `Oxxila Dev` or `Oxxila Prod` environment before sending requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "54107413",
    "_collection_link": "https://go.postman.co/collection/54107413-1e24d623-738e-4745-ad67-af09c0aca44c?source=collection_link"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health Check",
      "description": "Liveness probe — no auth required.",
      "item": [
        {
          "name": "Server Status",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [""] },
            "description": "Returns a simple 'Oxxila API is up and running' message. Use to confirm the server is reachable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "description": "Signup, login, session management, and password recovery.",
      "item": [
        {
          "name": "Signup & Login",
          "description": "Create an account, sign in, refresh the access token, or end the session.",
          "item": [
            {
              "name": "Signup",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const res = pm.response.json();",
                      "if (res?.data?.accessToken) {",
                      "  pm.environment.set('token', res.data.accessToken);",
                      "  if (res.data.user?.id) pm.environment.set('userId', res.data.user.id);",
                      "  console.log('Saved access token + userId (refresh cookie handled by Postman)');",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Mohamed Emad\",\n  \"email\": \"mohamed@example.com\",\n  \"password\": \"StrongPass123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/register",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "register"]
                },
                "description": "Creates a new account. Response body carries the 15-min access token; the 7-day refresh token is set as an httpOnly cookie. Saves `token` + `userId` to the active environment."
              },
              "response": []
            },
            {
              "name": "Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const res = pm.response.json();",
                      "if (res?.data?.accessToken) {",
                      "  pm.environment.set('token', res.data.accessToken);",
                      "  if (res.data.user?.id) pm.environment.set('userId', res.data.user.id);",
                      "  console.log('Saved access token + userId (refresh cookie handled by Postman)');",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"mohamed@example.com\",\n  \"password\": \"StrongPass123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "login"]
                },
                "description": "Validates credentials. Returns a 15-min access token in the response body and sets a 7-day refresh token as an httpOnly cookie scoped to `/api/v1/auth`. Saves `token` + `userId` to the active environment."
              },
              "response": []
            },
            {
              "name": "Refresh Access Token",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const res = pm.response.json();",
                      "if (res?.data?.accessToken) {",
                      "  pm.environment.set('token', res.data.accessToken);",
                      "  console.log('Rotated refresh cookie and saved new access token');",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/refresh",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "refresh"]
                },
                "description": "Reads the refresh token from the httpOnly cookie (Postman attaches it automatically), verifies it against the DB, rotates it (old is revoked, new one issued), and returns a fresh access token. Using a revoked refresh token revokes every session for the user (reuse detection)."
              },
              "response": []
            },
            {
              "name": "Logout",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/logout",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "logout"]
                },
                "description": "Revokes the current refresh token in DB and clears the cookie. Intentionally unauthenticated so an expired access token can't block logout."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Password Reset",
          "description": "Forgot-password flow. Both endpoints are unauthenticated.",
          "item": [
            {
              "name": "Forgot Password",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"mohamed@example.com\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "forgot-password"]
                },
                "description": "Sends a password-reset link to the user's email. The link points to `${CLIENT_URL}/reset-password/<token>`. Always responds 200 to avoid leaking which emails are registered."
              },
              "response": []
            },
            {
              "name": "Reset Password",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const res = pm.response.json();",
                      "if (res?.data?.accessToken) {",
                      "  pm.environment.set('token', res.data.accessToken);",
                      "  console.log('Saved new access token (all previous sessions revoked)');",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"newPassword\": \"NewStrongPass123\",\n  \"confirmPassword\": \"NewStrongPass123\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/v1/auth/reset-password/:token",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "v1", "auth", "reset-password", ":token"],
                  "variable": [
                    { "key": "token", "value": "", "description": "Plain reset token from the email link" }
                  ]
                },
                "description": "Validates the token from the email, checks that newPassword === confirmPassword, sets the new password, revokes every existing refresh session (logs out all devices), and returns a fresh access token + refresh cookie."
              },
              "response": []
            }
          ]
        },
        {
          "name": "Get Authenticated User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Returns the user decoded from the `Authorization: Bearer` access token. Useful right after Login/Refresh to confirm the session."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Current User",
      "description": "Self-service endpoints. All require a valid Bearer token.",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/getMe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "getMe"]
            },
            "description": "Returns the full profile document for the authenticated user."
          },
          "response": []
        },
        {
          "name": "Update Current User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mohamed E.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/updateMe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "updateMe"]
            },
            "description": "Whitelisted fields only: `name`, `email`, `avatar`. Password and role updates are rejected here. To change the avatar image, use **Upload Profile Image**."
          },
          "response": []
        },
        {
          "name": "Upload Profile Image",
          "request": {
            "method": "PATCH",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": [],
                  "description": "Image file — jpeg, jpg, png, or webp. Max 2 MB."
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/updateMyAvatar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "updateMyAvatar"]
            },
            "description": "Uploads a new avatar image to Cloudinary and replaces the previous one (old asset is destroyed). Send as `multipart/form-data` with a single `avatar` file field — do NOT set Content-Type manually, Postman adds the correct boundary.\n\nErrors:\n- `400` missing file, unsupported format, or larger than 2 MB\n- `401` no / invalid access token"
          },
          "response": []
        },
        {
          "name": "Change Current User Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"StrongPass123\",\n  \"newPassword\": \"EvenStrongerPass456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/updateMyPassword",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "updateMyPassword"]
            },
            "description": "Verifies `oldPassword`, then updates to `newPassword`. On success, `passwordChangedAt` is bumped so other sessions fail on next refresh."
          },
          "response": []
        },
        {
          "name": "Deactivate Current User",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/deactivateMe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "deactivateMe"]
            },
            "description": "Sets `active=false` on the current user. Subsequent auth checks will reject the token with 403."
          },
          "response": []
        },
        {
          "name": "Activate Current User",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/activateMe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "activateMe"]
            },
            "description": "Sets `active=true` on the current user."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin User Management",
      "description": "Admin-only operations on user accounts. Requires a Bearer token belonging to a user with role `admin`.",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=1&limit=10&sort=-createdAt",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "-createdAt", "description": "Comma-separated fields, prefix `-` for desc" },
                { "key": "fields", "value": "name,email,role", "disabled": true },
                { "key": "keyword", "value": "mohamed", "description": "Search in name + email (case-insensitive)", "disabled": true },
                { "key": "role", "value": "user", "disabled": true }
              ]
            },
            "description": "Supports filter (`?role=user`), search (`?keyword=...`), sort (`?sort=-createdAt`), field selection (`?fields=name,email`), and pagination (`?page`, `?limit`)."
          },
          "response": []
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Two\",\n  \"email\": \"admin2@example.com\",\n  \"password\": \"AdminPass123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            },
            "description": "Creates any user, including admins. Password is hashed by the User model's pre-save hook."
          },
          "response": []
        },
        {
          "name": "Get Specific User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", ":id"],
              "variable": [
                { "key": "id", "value": "{{userId}}", "description": "Mongo ObjectId" }
              ]
            },
            "description": "Fetches a single user by Mongo ObjectId. Returns 404 if not found."
          },
          "response": []
        },
        {
          "name": "Update Specific User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Name\",\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", ":id"],
              "variable": [{ "key": "id", "value": "{{userId}}" }]
            },
            "description": "Updates arbitrary fields on a user. Password and role changes are stripped — use **Change Specific User Password** for passwords, and a future dedicated endpoint for role changes."
          },
          "response": []
        },
        {
          "name": "Delete Specific User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", ":id"],
              "variable": [{ "key": "id", "value": "{{userId}}" }]
            },
            "description": "Hard-deletes a user document. Prefer **Deactivate Current User** for user-initiated offboarding."
          },
          "response": []
        },
        {
          "name": "Activate Specific User",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/activate/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "activate", ":id"],
              "variable": [{ "key": "id", "value": "{{userId}}" }]
            },
            "description": "Reactivates a previously deactivated account. Useful when a user's `deactivateMe` call needs to be undone by support."
          },
          "response": []
        },
        {
          "name": "Change Specific User Password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"ResetByAdmin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/changePassword/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "changePassword", ":id"],
              "variable": [{ "key": "id", "value": "{{userId}}" }]
            },
            "description": "Force-sets a user's password (no old-password check). The user's existing sessions become invalid on next refresh because `passwordChangedAt` is bumped."
          },
          "response": []
        }
      ]
    }
  ]
}
