# App settings
PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/dbname

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-DIFFERENT-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Base URL used in password-reset emails.
# Production client URL:
CLIENT_URL=https://oauthangular.onrender.com
# Temporary local fallback:
# CLIENT_URL=http://localhost:3000

# Gmail SMTP (use an App Password, not your real password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password

# Cloudinary (for avatar uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — comma-separated origins allowed with credentials.
# Add more origins as needed (e.g. Vite :5173, production URL).
# On Heroku: heroku config:set CORS_ORIGIN="http://localhost:4200,https://your-app.com"
# Production client origin:
CORS_ORIGIN=https://oauthangular.onrender.com
# Temporary local fallback:
# CORS_ORIGIN=http://localhost:4200

# Google OAuth 2.0 (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match exactly the "Authorized redirect URI" you saved in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# Where the backend should redirect the browser after a successful OAuth login.
# The access token is appended as a URL fragment (#accessToken=...), refresh token is set as httpOnly cookie.
OAUTH_SUCCESS_REDIRECT=https://oauthangular.onrender.com/oauth/success
OAUTH_FAILURE_REDIRECT=https://oauthangular.onrender.com/login?error=google_failed
# Temporary local fallback:
# OAUTH_SUCCESS_REDIRECT=http://localhost:4200/oauth/success
# OAUTH_FAILURE_REDIRECT=http://localhost:4200/login?error=google_failed

# Facebook Login (from Meta Developer App → Facebook Login → Settings)

# Optional; defaults to /login?error=facebook_failed
# FACEBOOK_OAUTH_FAILURE_REDIRECT=http://localhost:4200/login?error=facebook_failed
