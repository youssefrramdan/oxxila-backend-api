# App settings
PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/dbname

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-DIFFERENT-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Base URL used in password-reset emails. In production this is your Heroku app URL.
CLIENT_URL=http://localhost:3000

# Gmail SMTP (use an App Password, not your real password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password

# Cloudinary (for avatar uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
