# App settings
PORT=3000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/dbname

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-DIFFERENT-long-random-string
JWT_REFRESH_EXPIRES_IN=7d

# Base URL used in password-reset emails. In production this is your Heroku app URL.
CLIENT_URL=http://localhost:3000

# Gmail SMTP (use an App Password, not your real password)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password

# Inbox for "ask specialist" product questions (FAQ workflow)
ADMIN_EMAIL=your-admin@gmail.com

# Cloudinary (for avatar uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — comma-separated origins allowed with credentials (local Angular default).
# Add more origins as needed (e.g. Vite :5173, production URL).
# On Heroku: heroku config:set CORS_ORIGIN="http://localhost:4200,https://your-app.com"
CORS_ORIGIN=http://localhost:4200

# Google OAuth 2.0 (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match exactly the "Authorized redirect URI" you saved in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
# Where the backend should redirect the browser after a successful OAuth login.
# The access token is appended as a URL fragment (#accessToken=...), refresh token is set as httpOnly cookie.
OAUTH_SUCCESS_REDIRECT=http://localhost:4200/oauth/success
OAUTH_FAILURE_REDIRECT=http://localhost:4200/login?error=google_failed

# Admin seed (`npm run seed:admins`) — use a strong password in production
SEED_ADMIN_PASSWORD=change-me-min-8-chars
# Optional overrides (defaults: admin@oxxila.local / Oxxila Admin)
SEED_ADMIN_EMAIL=iti.intake.46@gmail.com

SEED_ADMIN_NAME=Oxxila Admin

# Stripe (card checkout — order created on webhook; refund sync on charge.refunded)
# Webhook events: checkout.session.completed, charge.refunded
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/checkout-test.html?paid=1
STRIPE_CANCEL_URL=http://localhost:4200/checkout/cancel
STRIPE_CURRENCY=egp

# Paymob Accept (card checkout — order created on processed callback)
# Dashboard → Developers → Payment Integrations → (card):
#   Processed callback URL (POST): https://YOUR_PUBLIC_HOST/api/v1/webhooks/paymob
#   Response callback URL (GET):   same URL, or PAYMOB_RETURN_URL for a frontend-only redirect
# Optional customer redirect after Paymob GET response (defaults to checkout-test.html)
# PAYMOB_RETURN_URL=http://localhost:3000/checkout-test.html
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID=123456
PAYMOB_IFRAME_ID=123456
PAYMOB_HMAC_SECRET=your-paymob-hmac-secret
PAYMOB_CURRENCY=EGP

# Returns — days after deliveredAt when customer can open a return request
RETURN_WINDOW_DAYS=14

# Facebook Login (from Meta Developer App → Facebook Login → Settings)

# Optional; defaults to /login?error=facebook_failed
# FACEBOOK_OAUTH_FAILURE_REDIRECT=http://localhost:4200/login?error=facebook_failed
